generator client {
  provider      = "prisma-client-js"
  output        = "./generated/prisma"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String     @id @default(uuid())
  email              String     @unique
  password           String
  role               UserRole
  needPasswordChange Boolean    @default(true)
  status             UserStatus @default(ACTIVE)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  admin              Admin?
  buyer              Buyer?
  manager            Manager?

  @@map("users")
}

model Admin {
  id            String    @id @default(uuid())
  name          String
  profilePhoto  String?
  contactNumber String
  isDeleted     Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  email         String    @unique
  user          User      @relation(fields: [email], references: [email])
  addresses     Address[]

  @@map("admins")
}

model Buyer {
  id            String    @id @default(uuid())
  name          String
  profilePhoto  String?
  contactNumber String
  isDeleted     Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  email         String    @unique
  user          User      @relation(fields: [email], references: [email])
  addresses     Address[]

  @@map("buyers")
}

model Manager {
  id            String    @id @default(uuid())
  name          String
  profilePhoto  String?
  contactNumber String
  isDeleted     Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  email         String    @unique
  user          User      @relation(fields: [email], references: [email])
  addresses     Address[]

  @@map("managers")
}

model Address {
  id                   String      @id @default(uuid())
  label                String? // ex: Home, Office
  addressType          AddressType @default(HOME)
  recipientName        String
  recipientPhone       String
  alternatePhone       String?
  line1                String
  line2                String?
  landmark             String?
  city                 String
  state                String
  postalCode           String
  country              String      @default("Bangladesh")
  latitude             Float?
  longitude            Float?
  deliveryInstructions String?
  isDefault            Boolean     @default(false)
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  adminId   String?
  buyerId   String?
  managerId String?
  admin   Admin?   @relation(fields: [adminId], references: [id], onDelete: SetNull)
  buyer   Buyer?   @relation(fields: [buyerId], references: [id], onDelete: SetNull)
  manager Manager? @relation(fields: [managerId], references: [id], onDelete: SetNull)
  @@index([adminId])
  @@index([buyerId])
  @@index([managerId])
  @@map("addresses")
}

enum UserRole {
  ADMIN
  BUYER
  MANAGER
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  BLOCKED
  DELETED
}

enum AddressType {
  HOME
  OFFICE
  OTHER
}
